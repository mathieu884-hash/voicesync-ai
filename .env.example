# ============================================
# VoiceSync AI - Environment Configuration
# ============================================

# Database
DATABASE_URL=postgresql://user:password@db:5432/voicesync_db
REDIS_URL=redis://redis:6379/0

# API Keys
OPENAI_API_KEY=sk-your-key-here
ELEVENLABS_API_KEY=your-key-here
DEEPL_API_KEY=your-key-here
WHISPER_API_KEY=your-key-here

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# AWS Configuration
AWS_ACCESS_KEY_ID=your-key-here
AWS_SECRET_ACCESS_KEY=your-secret-here
AWS_REGION=eu-west-1
AWS_S3_BUCKET=voicesync-ai-videos

# Google Cloud (Alternative to AWS)
GCP_PROJECT_ID=your-project-id
GCP_SERVICE_ACCOUNT_JSON=./gcp-service-account.json

# Application
APP_NAME=VoiceSync AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_STRIPE_KEY=pk_test_your-key-here

# Stripe (Payment)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=VoiceSync AI
SMTP_FROM_EMAIL=noreply@voicesync-ai.com

# File Upload
MAX_UPLOAD_SIZE=2147483648  # 2GB in bytes
ALLOWED_VIDEO_FORMATS=mp4,mkv,avi,mov,flv,webm
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,aac,ogg

# Processing
MAX_VIDEO_DURATION=3600  # 60 minutes in seconds
DEFAULT_OUTPUT_QUALITY=1080p
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT=7200  # 2 hours in seconds

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # 1 hour in seconds

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Feature Flags
FEATURE_VOICE_CLONING=true
FEATURE_REAL_TIME_SYNC=false
FEATURE_BATCH_PROCESSING=true
FEATURE_API_ACCESS=true
FEATURE_MARKETPLACE=false

# Model Configuration
WHISPER_MODEL_SIZE=base  # tiny, base, small, medium, large
WAV2LIP_MODEL=checkpoints/wav2lip.pth
VOICE_CLONING_MODEL=models/voice_cloning.pth

# Service URLs (for microservices)
TRANSCRIPTION_SERVICE_URL=http://transcription:8001
TRANSLATION_SERVICE_URL=http://translation:8002
VOICE_SYNTHESIS_SERVICE_URL=http://voice_synthesis:8003

# Celery (Task Queue)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Logging
LOG_FILE=/var/log/voicesync/app.log
LOG_FORMAT=json

# External Services (Content Protection)
COPYRIGHT_API_KEY=your-key-here
DRM_PROVIDER=widevine  # widevine, playready, fairplay

# Analytics
GOOGLE_ANALYTICS_ID=UA-your-id
MIXPANEL_TOKEN=your-token

# Development
DEVELOPER_MODE=true
SKIP_EMAIL_VERIFICATION=false
MOCK_EXTERNAL_APIS=false
